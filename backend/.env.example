NODE_ENV=production
PORT=4000

# Set by Railway PostgreSQL plugin automatically
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to "postgresql" for production, "sqlite" for local dev
DATABASE_PROVIDER=postgresql

JWT_SECRET=replace-with-32-char-random-string
JWT_REFRESH_SECRET=replace-with-another-32-char-random-string

# Optional
REDIS_URL=
